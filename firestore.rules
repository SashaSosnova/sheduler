rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Семейный код = id документа. Любой анонимно вошедший,
    // кто знает код, может читать и писать данные семьи.
    match /families/{familyCode} {
      allow read, write: if request.auth != null;
    }

    // Tom Sawyer reader (отдельная коллекция в том же проекте)
    match /tomSawyerFamilies/{familyCode} {
      allow read, write: if request.auth != null;
    }

    // Planer — личный трекер (doc id = auth.uid)
    match /planer/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /planer/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
